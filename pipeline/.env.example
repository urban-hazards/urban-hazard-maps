# Local development defaults — points at MinIO started by `docker compose up -d`
# Copy this file to `.env` (which is gitignored) and adjust as needed.
#
# In production, these are set by Railway to point at the Tigris bucket.

BUCKET=boston-hazards
ACCESS_KEY_ID=minioadmin
SECRET_ACCESS_KEY=minioadmin
ENDPOINT=http://localhost:9000
REGION=us-east-1
