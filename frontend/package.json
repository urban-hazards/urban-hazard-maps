    "@aws-sdk/client-s3": "^3.1024.0",
    "astro": "^6.1.3",
    "chart.js": "^4.5.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
