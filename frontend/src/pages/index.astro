---
import Footer from "../components/Footer.astro"
import Header from "../components/Header.astro"
import HeatMap from "../components/HeatMap"
import HourlyChart from "../components/HourlyChart"
import MonthlyTrend from "../components/MonthlyTrend"
import NeighborhoodTable from "../components/NeighborhoodTable"
import StatsOverview from "../components/StatsOverview.astro"
import ZipCodeList from "../components/ZipCodeList.astro"
import BaseLayout from "../layouts/BaseLayout.astro"
import { fetchMarkers, fetchPageStats, fetchPoints } from "../lib/bucket"
import { formatNumber } from "../lib/seo"
import "../styles/global.css"

const [
	stats,
	encampmentStats,
	wasteStats,
	needlePoints,
	encampmentPoints,
	wastePoints,
	needleMarkers,
	encampmentMarkers,
	wasteMarkers,
] = await Promise.all([
	fetchPageStats("needles"),
	fetchPageStats("encampments"),
	fetchPageStats("waste"),
	fetchPoints("needles"),
	fetchPoints("encampments"),
	fetchPoints("waste"),
	fetchMarkers("needles"),
	fetchMarkers("encampments"),
	fetchMarkers("waste"),
])

function addSlugs(hoods: typeof stats.hoods) {
	return hoods.map((h) => ({
		...h,
		slug:
			h.slug ||
			h.name
				.toLowerCase()
				.replace(/[^a-z0-9]+/g, "-")
				.replace(/^-|-$/g, ""),
	}))
}
const neighborhoods = addSlugs(stats.hoods)
const encampmentNeighborhoods = addSlugs(encampmentStats.hoods)
const wasteNeighborhoods = addSlugs(wasteStats.hoods)

const title = `Boston Urban Hazard Maps — ${formatNumber(stats.total + encampmentStats.total)} Reports Analyzed`
const description = `Interactive heatmap and analysis of ${formatNumber(stats.total)} sharps and ${formatNumber(encampmentStats.total)} encampment reports from Boston's 311 system across ${stats.hoods.length} neighborhoods. Data from ${stats.years[0]}–${stats.years[stats.years.length - 1]}.`
---

<BaseLayout title={title} description={description} jsonLd={{
	"@context": "https://schema.org",
	"@type": "Dataset",
	name: "Boston Urban Hazard Maps",
	description: "Interactive analysis of sharps collection and encampment requests reported through Boston's 311 system. Derived from open municipal data.",
	url: "https://www.urbanhazardmaps.com",
	license: "https://opensource.org/licenses/MIT",
	creator: { "@type": "Organization", name: "Urban Hazards" },
	distribution: { "@type": "DataDownload", encodingFormat: "application/json", contentUrl: "https://www.urbanhazardmaps.com/api/stats" },
}}>
	<Header generated={stats.generated} />

	<main class="container" style="padding-top: 32px; padding-bottom: 48px;">
		<h1 class="page-title">
			Boston Urban Hazard Maps
		</h1>
		<p class="page-subtitle">
			Interactive analysis of {formatNumber(stats.total)} sharps collection requests
			and {formatNumber(encampmentStats.total)} encampment reports
			submitted to Boston's 311 system from {stats.years[0]} to {stats.years[stats.years.length - 1]}.
			Sourced from the <a href="https://data.boston.gov/dataset/311-service-requests" target="_blank" rel="noopener">City of Boston's open data portal</a>,
			updated regularly for public health research and community awareness.
		</p>

		<StatsOverview
			total={stats.total}
			peakHood={stats.peak_hood}
			peakHour={stats.peak_hour}
			peakDow={stats.peak_dow}
			avgMonthly={stats.avg_monthly}
			neighborhoodCount={stats.hoods.length}
			years={stats.years}
		/>

		<HeatMap
			client:load
			needlePoints={needlePoints}
			encampmentPoints={encampmentPoints}
			wastePoints={wastePoints}
			needleMarkers={needleMarkers}
			encampmentMarkers={encampmentMarkers}
			wasteMarkers={wasteMarkers}
			years={stats.years}
			encampmentYears={encampmentStats.years}
			wasteYears={wasteStats.years}
			total={stats.total}
			encampmentTotal={encampmentStats.total}
			wasteTotal={wasteStats.total}
		/>

		<section class="section" aria-label="Trend charts">
			<h2 class="section-title">Trends &amp; Patterns</h2>
			<div class="charts-grid">
				<MonthlyTrend client:visible yearMonthly={stats.year_monthly} />
				<HourlyChart
					client:visible
					datasets={{
						Sharps: { hourly: stats.hourly, yearHourly: stats.year_hourly, years: stats.years },
						Encampments: { hourly: encampmentStats.hourly, yearHourly: encampmentStats.year_hourly, years: encampmentStats.years },
						"Human Waste": { hourly: wasteStats.hourly, yearHourly: wasteStats.year_hourly, years: wasteStats.years },
					}}
				/>
			</div>
		</section>

		<NeighborhoodTable
			client:visible
			datasets={{
				Sharps: { hoods: neighborhoods, years: stats.years, label: "Sharps", color: "#e85a1b" },
				Encampments: { hoods: encampmentNeighborhoods, years: encampmentStats.years, label: "Encampments", color: "#7b2d8e" },
				"Human Waste": { hoods: wasteNeighborhoods, years: wasteStats.years, label: "Human Waste", color: "#8B6914" },
			}}
		/>

		<ZipCodeList zipStats={stats.zip_stats} />

		<section class="section about-section" aria-label="About this data">
			<h2 class="section-title">About This Data</h2>
			<div class="card about-content">
				<p>
					This dashboard maps publicly available data from Boston's
					<a href="https://data.boston.gov/dataset/311-service-requests" target="_blank" rel="noopener">311 open data portal</a>.
					Boston's 311 system is the city's non-emergency service request platform — residents use it to
					report everything from potholes to graffiti to discarded needles.
				</p>
				<p>
					We currently display two datasets: <strong>sharps collection requests</strong> ({formatNumber(stats.total)} reports)
					and <strong>encampment reports</strong> ({formatNumber(encampmentStats.total)} reports).
					We also use <a href="/methodology">NLP classification</a> to detect <strong>human waste reports</strong> hidden
					in street cleaning requests.
					These are separate, unrelated complaint types that happen to be available through the same API.
					We are not implying any correlation or causation between them — we're simply mapping the data
					as the city provides it. As more geolocated 311 categories become available, we may add them.
				</p>
				<p>
					All data is sourced from the <a href="https://data.boston.gov/dataset/311-service-requests" target="_blank" rel="noopener">City of Boston Open Data Portal</a>
					via the CKAN API. This project is open source under the MIT license and intended for
					public health research and community awareness.
				</p>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>

<style>
	.page-title {
		font-size: var(--fs-2xl);
		margin-bottom: 8px;
		position: relative;
		padding-bottom: 16px;
	}

	.page-title::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 60px;
		height: 3px;
		background: var(--color-accent);
		border-radius: 2px;
	}

	.page-subtitle {
		font-size: var(--fs-md);
		line-height: 1.7;
		color: var(--color-text-muted);
		margin-bottom: var(--sp-xl);
		max-width: 900px;
	}

	.charts-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	.about-content {
		line-height: 1.7;
		font-size: var(--fs-base);
		color: var(--color-text-muted);
		border-left: 3px solid var(--color-teal);
	}

	.about-content p {
		margin-bottom: 12px;
	}

	.about-content p:last-child {
		margin-bottom: 0;
	}

	@media (max-width: 768px) {
		.charts-grid {
			grid-template-columns: 1fr;
		}

		.page-title {
			font-size: 22px;
		}
	}
</style>
