---
import Footer from "../../components/Footer.astro"
import Header from "../../components/Header.astro"
import BaseLayout from "../../layouts/BaseLayout.astro"
import { fetchPageStats } from "../../lib/bucket"
import { formatNumber } from "../../lib/seo"
import "../../styles/global.css"

const { slug } = Astro.params

const stats = await fetchPageStats("needles")

const neighborhood = stats.hoods.find((h) => {
	const hSlug = h.name
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-|-$/g, "")
	return hSlug === slug
})

if (!neighborhood) {
	return Astro.redirect("/")
}

const title = `${neighborhood.name} — Sharps Collection Requests | Boston 311`
const description = `${neighborhood.name} has ${formatNumber(neighborhood.count)} sharps collection requests (${neighborhood.pct}% of citywide total). Top location: ${neighborhood.top_street}. Average response time: ${neighborhood.avg_resp} hours.`
---

<BaseLayout title={title} description={description} jsonLd={{
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: title,
	description: description,
	breadcrumb: {
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: "https://www.urbanhazardmaps.com" },
			{ "@type": "ListItem", position: 2, name: neighborhood.name, item: `https://www.urbanhazardmaps.com/neighborhoods/${slug}` },
		],
	},
}}>
	<Header generated={stats.generated} />

	<main class="container" style="padding-top: 32px; padding-bottom: 48px;">
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/">Home</a> <span class="breadcrumb-sep">&rsaquo;</span>
			<span class="breadcrumb-current">{neighborhood.name}</span>
		</nav>

		<h1 class="page-title">{neighborhood.name}</h1>
		<p class="page-subtitle">
			Sharps collection request data for the {neighborhood.name} neighborhood in Boston.
			This area accounts for <strong>{neighborhood.pct}%</strong> of all citywide sharps
			collection requests, with <strong>{formatNumber(neighborhood.count)}</strong> total
			reports. The most frequently reported location is
			<strong>{neighborhood.top_street}</strong>, and the average city response time for
			this neighborhood is <strong>{neighborhood.avg_resp} hours</strong>.
		</p>

		<div class="stats-grid">
			<div class="card stat-card primary">
				<div class="stat-value">{formatNumber(neighborhood.count)}</div>
				<div class="stat-label">Total Requests</div>
			</div>
			<div class="card stat-card">
				<div class="stat-value">{neighborhood.pct}%</div>
				<div class="stat-label">Share of Citywide Total</div>
			</div>
			<div class="card stat-card">
				<div class="stat-value">{neighborhood.top_street}</div>
				<div class="stat-label">Most Reported Street</div>
			</div>
			<div class="card stat-card">
				<div class="stat-value">{neighborhood.avg_resp}h</div>
				<div class="stat-label">Average Response Time</div>
			</div>
		</div>

		<section class="section">
			<h2 class="section-title">Context</h2>
			<div class="card about-content">
				<p>
					{neighborhood.name} is one of {stats.hoods.length} Boston neighborhoods that report sharps
					collection needs through the 311 system. With {formatNumber(neighborhood.count)} requests,
					it ranks as a significant area for public health intervention.
				</p>
				<p>
					The average response time of {neighborhood.avg_resp} hours reflects the city's
					capacity to address sharps collection in this area. Response times can vary based on
					request volume, crew availability, and seasonal patterns.
				</p>
			</div>
		</section>

		<nav class="section">
			<h2 class="section-title">Other Neighborhoods</h2>
			<div class="hood-links">
				{stats.hoods
					.filter((h) => h.name !== neighborhood.name)
					.map((h) => {
						const s = h.name
							.toLowerCase()
							.replace(/[^a-z0-9]+/g, "-")
							.replace(/^-|-$/g, "")
						return (
							<a href={`/neighborhoods/${s}`} class="hood-link">
								{h.name} <span class="hood-link-count">({formatNumber(h.count)})</span>
							</a>
						)
					})}
			</div>
		</nav>
	</main>

	<Footer />
</BaseLayout>

<style>
	.breadcrumb {
		font-size: var(--fs-sm);
		color: var(--color-text-muted);
		margin-bottom: 16px;
		padding: 8px 12px;
		background: var(--color-surface);
		border: 1px solid var(--color-border-light);
		border-radius: var(--radius-sm);
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.breadcrumb-sep {
		color: var(--color-text-light);
	}

	.breadcrumb-current {
		font-weight: 600;
		color: var(--color-text);
	}

	.page-title {
		font-size: var(--fs-2xl);
		margin-bottom: 8px;
		position: relative;
		padding-bottom: 16px;
	}

	.page-title::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 60px;
		height: 3px;
		background: var(--color-accent);
		border-radius: 2px;
	}

	.page-subtitle {
		font-size: var(--fs-md);
		line-height: 1.7;
		color: var(--color-text-muted);
		margin-bottom: var(--sp-lg);
		max-width: 800px;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 16px;
		margin-bottom: var(--sp-xl);
	}

	.stat-card {
		text-align: center;
		padding: 20px 16px;
	}

	.stat-card.primary {
		border-top: 3px solid var(--color-accent);
	}

	.about-content {
		line-height: 1.7;
		font-size: var(--fs-base);
		color: var(--color-text-muted);
		border-left: 3px solid var(--color-teal);
	}

	.about-content p {
		margin-bottom: 12px;
	}

	.about-content p:last-child {
		margin-bottom: 0;
	}

	.hood-links {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.hood-link {
		display: inline-block;
		padding: 8px 14px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		font-size: var(--fs-sm);
		color: var(--color-text);
		text-decoration: none;
		transition: border-color 0.15s, box-shadow 0.15s;
	}

	.hood-link:hover {
		border-color: var(--color-accent);
		box-shadow: var(--shadow-xs);
		text-decoration: none;
	}

	.hood-link-count {
		color: var(--color-text-muted);
	}

	@media (max-width: 640px) {
		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.page-title {
			font-size: 22px;
		}
	}
</style>
