---
interface Props {
	title: string
	description: string
	canonical?: string
}

const { title, description, canonical } = Astro.props
const siteUrl = "https://www.urbanhazardmaps.com"
// Normalize: strip trailing slash, always use www
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/"
const canonicalUrl = canonical || new URL(pathname, siteUrl).toString()
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#e85a1b" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Boston Urban Hazard Maps" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<link
			rel="preconnect"
			href="https://fonts.googleapis.com"
		/>
		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>

		<link
			rel="stylesheet"
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
		/>
	</head>
	<body>
		<slot />

		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "Dataset",
				name: "Boston Urban Hazard Maps",
				description:
					"Interactive analysis of sharps collection and encampment requests reported through Boston's 311 system. Derived from open municipal data.",
				url: siteUrl,
				license: "https://opensource.org/licenses/MIT",
				creator: {
					"@type": "Organization",
					name: "Urban Hazards",
				},
				distribution: {
					"@type": "DataDownload",
					encodingFormat: "text/html",
					contentUrl: siteUrl,
				},
			})}
		/>
	</body>
</html>
