---
import { formatNumber } from "../lib/seo"
import type { ZipStat } from "../lib/types"

interface Props {
	zipStats: ZipStat[]
}

const { zipStats } = Astro.props
const maxCount = zipStats[0]?.count ?? 1
---

<section class="section" aria-label="Top zip codes">
	<h2 class="section-title">Top Zip Codes</h2>
	<p class="section-desc">
		The most active zip codes for sharps collection requests, led by <strong>{zipStats[0]?.zip}</strong> with
		<strong>{formatNumber(zipStats[0]?.count ?? 0)}</strong> reports.
	</p>
	<div class="card">
		<div class="zip-list">
			{zipStats.map((z) => {
				const barWidth = Math.max(2, Math.round((z.count / maxCount) * 100))
				return (
					<div class="zip-row">
						<span class="zip-label">{z.zip}</span>
						<div class="zip-bar-wrap">
							<div class="zip-bar" style={`width: ${barWidth}%`} />
						</div>
						<span class="zip-count">{formatNumber(z.count)}</span>
					</div>
				)
			})}
		</div>
	</div>
</section>

<style>
	.section-desc {
		font-size: var(--fs-base);
		color: var(--color-text-muted);
		margin-bottom: 16px;
		max-width: 800px;
		line-height: 1.6;
	}

	.zip-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.zip-row {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: var(--fs-sm);
	}

	.zip-label {
		width: 55px;
		color: var(--color-text-muted);
		font-weight: 600;
		flex-shrink: 0;
		font-variant-numeric: tabular-nums;
	}

	.zip-bar-wrap {
		flex: 1;
		background: var(--color-border-light);
		border-radius: 5px;
		overflow: hidden;
	}

	.zip-bar {
		height: 10px;
		border-radius: 5px;
		background: var(--color-teal);
	}

	.zip-count {
		width: 55px;
		text-align: right;
		color: var(--color-text);
		font-weight: 600;
		font-variant-numeric: tabular-nums;
	}
</style>
