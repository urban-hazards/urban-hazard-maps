---
import { formatNumber } from "../lib/seo"
import type { NeighborhoodStat } from "../lib/types"

interface Props {
	neighborhoods: NeighborhoodStat[]
}

const { neighborhoods } = Astro.props
const maxCount = neighborhoods[0]?.count ?? 1
---

<section class="section" aria-label="Neighborhood breakdown">
	<h2 class="section-title">Requests by Neighborhood</h2>
	<p class="section-desc">
		The table below shows the distribution of sharps collection requests across Boston
		neighborhoods. <strong>{neighborhoods[0]?.name}</strong> leads with
		<strong>{formatNumber(neighborhoods[0]?.count ?? 0)}</strong> requests
		({neighborhoods[0]?.pct}% of total), with the most reported location being
		<strong>{neighborhoods[0]?.top_street}</strong>.
	</p>
	<div class="card table-wrap">
		<table class="hood-table">
			<caption class="sr-only">Sharps collection requests by Boston neighborhood</caption>
			<thead>
				<tr>
					<th scope="col">Neighborhood</th>
					<th scope="col">Volume</th>
					<th scope="col" class="text-right">Requests</th>
					<th scope="col" class="text-right">Share</th>
					<th scope="col">Top Street</th>
					<th scope="col" class="text-right">Avg Response (hrs)</th>
				</tr>
			</thead>
			<tbody>
				{neighborhoods.map((h) => {
					const barWidth = Math.max(2, Math.round((h.count / maxCount) * 100))
					return (
						<tr>
							<td>
								<a href={`/neighborhoods/${h.slug}`}>{h.name}</a>
							</td>
							<td class="bar-cell">
								<div class="bar" style={`width: ${barWidth}%`} />
							</td>
							<td class="text-right count">{formatNumber(h.count)}</td>
							<td class="text-right">{h.pct}%</td>
							<td class="street">{h.top_street}</td>
							<td class="text-right">{h.avg_resp}</td>
						</tr>
					)
				})}
			</tbody>
		</table>
	</div>
</section>

<style>
	.section-desc {
		font-size: 15px;
		color: var(--color-text-muted);
		margin-bottom: 16px;
		max-width: 800px;
		line-height: 1.6;
	}

	.table-wrap {
		overflow-x: auto;
	}

	.hood-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 13px;
	}

	.hood-table th {
		text-align: left;
		font-size: 11px;
		font-weight: 700;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 8px 6px;
		border-bottom: 2px solid var(--color-border);
	}

	.hood-table td {
		padding: 6px;
		border-bottom: 1px solid var(--color-border-light);
		vertical-align: middle;
	}

	.hood-table tr:hover {
		background: #f9f9f9;
	}

	.bar-cell {
		width: 30%;
	}

	.bar {
		height: 8px;
		border-radius: 4px;
		background: var(--color-blue);
	}

	.count {
		color: var(--color-accent);
		font-weight: 600;
	}

	.street {
		color: var(--color-text-muted);
		max-width: 140px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.text-right {
		text-align: right;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 768px) {
		.street,
		.hood-table th:nth-child(5),
		.hood-table td:nth-child(5),
		.hood-table th:nth-child(6),
		.hood-table td:nth-child(6) {
			display: none;
		}
	}
</style>
