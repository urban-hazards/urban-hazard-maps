---
interface Props {
	generated: string
}

const { generated } = Astro.props
---

<header class="header">
	<div class="container header-inner">
		<div class="header-left">
			<a href="/" class="header-title">Boston Urban Hazard Maps</a>
			<span class="header-sub">311 sharps &amp; encampment data</span>
		</div>
		<nav class="header-nav">
			<a href="/methodology" class="nav-link">Methodology</a>
		</nav>
		<div class="header-right">
			<span class="header-meta">
				Data: <a
					href="https://data.boston.gov/dataset/311-service-requests"
					target="_blank"
					rel="noopener">data.boston.gov</a
				>
				&middot; Updated {generated}
			</span>
			<a
				href="https://github.com/urban-hazards/urban-hazard-maps"
				target="_blank"
				rel="noopener"
				class="github-link"
				aria-label="View source on GitHub"
			>
				<svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</div>
</header>

<style>
	.header {
		background: var(--color-surface);
		border-bottom: 1px solid var(--color-border);
		padding: 14px 0;
		box-shadow: var(--shadow-sm);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.header-left {
		display: flex;
		align-items: baseline;
		gap: 10px;
		min-width: 0;
	}

	.header-title {
		font-size: 20px;
		font-weight: 700;
		color: var(--color-text);
		text-decoration: none;
		white-space: nowrap;
	}

	.header-title:hover {
		color: var(--color-accent);
		text-decoration: none;
	}

	.header-sub {
		font-size: 13px;
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	.header-nav {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.nav-link {
		font-size: 14px;
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 600;
	}

	.nav-link:hover {
		color: var(--color-accent);
		text-decoration: none;
	}

	.header-right {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-shrink: 0;
	}

	.header-meta {
		font-size: 12px;
		color: var(--color-text-light);
	}

	.github-link {
		display: flex;
		align-items: center;
		color: var(--color-text-muted);
		transition: color 0.2s ease;
	}

	.github-link:hover {
		color: var(--color-text);
		text-decoration: none;
	}

	@media (max-width: 640px) {
		.header-sub {
			display: none;
		}

		.header-meta {
			display: none;
		}

		.header-title {
			font-size: 17px;
		}
	}
</style>
