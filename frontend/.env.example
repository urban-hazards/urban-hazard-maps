# Option 1: Backend API fallback (needles + encampments only, no waste)
API_URL=http://localhost:8000

# Option 2: Read from S3 bucket (all datasets, matches production)
# Easiest way: `railway run -- pnpm dev` injects these automatically.
# ENDPOINT=https://t3.storageapi.dev
# BUCKET=boston-hazard-data-yh2sfl
# ACCESS_KEY_ID=<from Railway>
# SECRET_ACCESS_KEY=<from Railway>
# REGION=auto
